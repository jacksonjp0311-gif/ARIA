{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aria.local/schema/aria-opcode-registry.schema.json",
  "title": "ARIA Opcode Registry",
  "type": "object",
  "required": ["format", "version", "opcodes"],
  "properties": {
    "format": { "const": "aria.opcode-registry" },
    "version": { "type": "string" },
    "opcodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "pops", "pushes", "effect"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "pops": { "type": "integer", "minimum": 0 },
          "pushes": { "type": "integer", "minimum": 0 },
          "effect": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
