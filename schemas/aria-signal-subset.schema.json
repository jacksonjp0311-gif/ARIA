{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://aria.local/schemas/aria-signal-subset.schema.json",
  "title":"ARIA Signal Subset",
  "type":"object",
  "additionalProperties":false,
  "required":["format","version","purpose","source","fields","excludedFields","sourceCount","emittedCount","limit","consent","items","digest"],
  "properties":{
    "format":{"const":"aria.signal-subset"},
    "version":{"const":1},
    "purpose":{"type":"string","minLength":1},
    "source":{"type":"string","minLength":1},
    "fields":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},
    "excludedFields":{"type":"array","uniqueItems":true,"items":{"type":"string","minLength":1}},
    "sourceCount":{"type":"integer","minimum":0},
    "emittedCount":{"type":"integer","minimum":0},
    "limit":{"type":"integer","minimum":1,"maximum":4096},
    "consent":{"type":"object","additionalProperties":false,"required":["basis","scope","retention"],"properties":{
      "basis":{"type":"string","minLength":1},
      "scope":{"type":"string","minLength":1},
      "retention":{"enum":["session","day","week","release","indefinite"]}
    }},
    "items":{"type":"array"},
    "digest":{"type":"string","pattern":"^[a-f0-9]{64}$"}
  }
}